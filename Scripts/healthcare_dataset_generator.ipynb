"""# **11. Generating Insurance Policies**"""

# ============================================
# Generates Insurance Policies
# ============================================

policy_data = []

policy_id = 1

insured_patients = random.sample(range(1,10001),8000)

for patient_id in insured_patients:

    start_date = fake.date_between(
        start_date="-5y",
        end_date="-1y"
    )

    end_date = fake.date_between(
        start_date="today",
        end_date="+5y"
    )

    policy_data.append({
        "policy_id": policy_id,
        "patient_id": patient_id,
        "provider_id": random.randint(1,15),
        "policy_number": f"POL{100000+policy_id}",
        "coverage_amount": random.choice([
            100000,
            200000,
            300000,
            500000,
            1000000
        ]),
        "start_date": start_date,
        "end_date": end_date
    })

    policy_id += 1

policy_df = pd.DataFrame(policy_data)

policy_df.to_csv(
    DATA_FOLDER/"insurance_policies.csv",
    index=False
)

