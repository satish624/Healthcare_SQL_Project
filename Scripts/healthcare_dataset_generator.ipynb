"""#**12. Generating Claims sheet**"""

# ============================================
# Generates Claims
# ============================================

claim_status = [
    "Pending",
    "Approved",
    "Rejected"
]

claim_data = []

claim_id = 1

insured_lookup = policy_df.set_index("patient_id")

completed = appointment_df[
    appointment_df["appointment_status"]=="Completed"
]

for _, appointment in completed.iterrows():

    patient = appointment["patient_id"]

    if patient in insured_lookup.index:

        policy = insured_lookup.loc[patient]

        fee = appointment["consultation_fee"]

        claim_data.append({
            "claim_id": claim_id,
            "policy_id": int(policy["policy_id"]),
            "appointment_id": int(appointment["appointment_id"]),
            "claim_amount": fee,
            "approved_amount": fee * random.uniform(0.6,1.0),
            "claim_status": random.choices(
                claim_status,
                weights=[10,75,15]
            )[0],
            "claim_date": appointment["appointment_date"].date()
        })

        claim_id += 1

claim_df = pd.DataFrame(claim_data)

claim_df.to_csv(
    DATA_FOLDER/"claims.csv",
    index=False
)

claim_df.head()

len(claim_df)

