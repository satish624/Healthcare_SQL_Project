]

department_data = []

department_id = 1

for hospital_id in range(1, 21):

    selected_departments = random.sample(
        department_names,
        random.randint(8, 12)
    )

    floor = 1

    for dept in selected_departments:

        department_data.append({
            "department_id": department_id,
            "hospital_id": hospital_id,
            "department_name": dept,
            "floor_number": floor,
